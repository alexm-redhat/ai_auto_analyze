+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Tests for FA3 Sparse MLA Attention Backend.
+
+Tests the FA3-based sparse MLA attention kernel (page_size=1 paged KV)
+for correctness and performance vs a naive reference implementation.
+"""
+
+import time
+
+import pytest
+import torch
+
+from vllm.platforms import current_platform
+
+# Skip if not CUDA SM90
+if not current_platform.is_cuda():
+    pytest.skip("FA3 Sparse MLA tests require CUDA", allow_module_level=True)
+
+device_cap = current_platform.get_device_capability()
+if device_cap is None or device_cap.major != 9:
+    pytest.skip(
+        "FA3 Sparse MLA tests require SM90 (Hopper)",
+        allow_module_level=True,
+    )
+
+from vllm.vllm_flash_attn import (  # type: ignore[attr-defined]  # noqa: E402
+    flash_attn_varlen_func,
+    get_scheduler_metadata,
+)
+
+
+def _reference_sparse_mla_attention(
+    q_nope: torch.Tensor,
+    q_pe: torch.Tensor,
+    kv_c_cache: torch.Tensor,
+    k_pe_cache: torch.Tensor,
+    topk_indices: torch.Tensor,
+    scale: float,
+) -> torch.Tensor:
+    """Naive reference implementation of sparse MLA attention.
+
+    Args:
+        q_nope: (B, H, kv_lora_rank)  e.g. (B, 16, 512)
+        q_pe: (B, H, qk_rope_dim)     e.g. (B, 16, 64)
+        kv_c_cache: (total_slots, kv_lora_rank) e.g. (total, 512)
+        k_pe_cache: (total_slots, qk_rope_dim)  e.g. (total, 64)
+        topk_indices: (B, topk) global slot indices
+        scale: softmax scale factor
+
+    Returns:
+        output: (B, H, kv_lora_rank) e.g. (B, 16, 512)
+    """
+    B, H, _ = q_nope.shape
+    topk = topk_indices.shape[1]
+
+    outputs = []
+    for b in range(B):
+        # Gather sparse KV entries for this batch element
+        indices = topk_indices[b]  # (topk,)
+        kv_c = kv_c_cache[indices]  # (topk, 512)
+        k_pe = k_pe_cache[indices]  # (topk, 64)
+
+        # Compute attention scores: q_nope @ kv_c^T + q_pe @ k_pe^T
+        # q_nope[b]: (H, 512), kv_c: (topk, 512)
+        score_nope = torch.matmul(
+            q_nope[b].float(), kv_c.float().T
+        )  # (H, topk)
+        # q_pe[b]: (H, 64), k_pe: (topk, 64)
+        score_pe = torch.matmul(
+            q_pe[b].float(), k_pe.float().T
+        )  # (H, topk)
+
+        scores = (score_nope + score_pe) * scale  # (H, topk)
+
+        # Softmax
+        attn_weights = torch.softmax(scores, dim=-1)  # (H, topk)
+
+        # Output: attn_weights @ kv_c
+        # attn_weights: (H, topk), kv_c: (topk, 512)
+        out = torch.matmul(attn_weights, kv_c.float())  # (H, 512)
+        outputs.append(out)
+
+    return torch.stack(outputs).to(q_nope.dtype)  # (B, H, 512)
+
+
+@pytest.mark.parametrize("batch_size", [1, 2, 4])
+@pytest.mark.parametrize("topk", [64, 256, 512])
+@pytest.mark.parametrize("num_heads", [16])
+def test_fa3_sparse_mla_correctness(batch_size, topk, num_heads):
+    """Test FA3 page_size=1 MLA correctness vs naive reference."""
+    torch.manual_seed(42)
+    dtype = torch.bfloat16
+    kv_lora_rank = 512
+    qk_rope_dim = 64
+    total_slots = 4096  # Total KV cache slots
+    scale = qk_rope_dim ** (-0.5)
+
+    # Create inputs
+    q_nope = torch.randn(
+        batch_size, num_heads, kv_lora_rank, device="cuda", dtype=dtype
+    )
+    q_pe = torch.randn(
+        batch_size, num_heads, qk_rope_dim, device="cuda", dtype=dtype
+    )
+
+    # Create flat KV cache (simulating page_size=1)
+    kv_c_cache = torch.randn(
+        total_slots, kv_lora_rank, device="cuda", dtype=dtype
+    )
+    k_pe_cache = torch.randn(
+        total_slots, qk_rope_dim, device="cuda", dtype=dtype
+    )
+
+    # Create topk_indices: random subset of cache slots per batch element
+    topk_indices = torch.stack(
+        [
+            torch.randperm(total_slots, device="cuda")[:topk]
+            for _ in range(batch_size)
+        ]
+    ).to(torch.int32)
+
+    # Reference implementation
+    ref_output = _reference_sparse_mla_attention(
+        q_nope, q_pe, kv_c_cache, k_pe_cache, topk_indices, scale
+    )
+
+    # FA3 implementation
+    # Reshape for page_size=1: (total_slots, 1, 1, dim)
+    k_pe_paged = k_pe_cache.view(total_slots, 1, 1, qk_rope_dim)
+    kv_c_paged = kv_c_cache.view(total_slots, 1, 1, kv_lora_rank)
+
+    # cu_seqlens_q for varlen: each batch element has 1 query token
+    cu_seqlens_q = torch.arange(
+        0, batch_size + 1, device="cuda", dtype=torch.int32
+    )
+
+    # seqused_k: all elements = topk
+    seqused_k = torch.full(
+        (batch_size,), topk, device="cuda", dtype=torch.int32
+    )
+
+    # Reshape q for varlen format: (total_q, num_heads, dim)
+    q_pe_varlen = q_pe.view(batch_size, num_heads, qk_rope_dim)
+    q_nope_varlen = q_nope.view(batch_size, num_heads, kv_lora_rank)
+
+    # Get scheduler metadata
+    sched_meta = get_scheduler_metadata(
+        batch_size=batch_size,
+        max_seqlen_q=1,
+        max_seqlen_k=topk,
+        num_heads_q=num_heads,
+        num_heads_kv=1,
+        headdim=qk_rope_dim,
+        cache_seqlens=seqused_k,
+        qkv_dtype=dtype,
+        headdim_v=kv_lora_rank,
+        page_size=1,
+        cu_seqlens_q=cu_seqlens_q,
+        causal=True,
+        num_splits=0,
+    )
+
+    fa3_output = flash_attn_varlen_func(
+        q=q_pe_varlen,
+        k=k_pe_paged,
+        v=kv_c_paged,
+        q_v=q_nope_varlen,
+        max_seqlen_q=1,
+        cu_seqlens_q=cu_seqlens_q,
+        max_seqlen_k=topk,
+        seqused_k=seqused_k,
+        block_table=topk_indices,
+        softmax_scale=scale,
+        causal=True,
+        fa_version=3,
+        scheduler_metadata=sched_meta,
+        num_splits=0,
+    )
+
+    # Compare outputs
+    # FA3 output: (total_q, num_heads, kv_lora_rank)
+    fa3_out = fa3_output.view(batch_size, num_heads, kv_lora_rank)
+
+    # Allow reasonable tolerance for bf16 precision
+    torch.testing.assert_close(
+        fa3_out.float(),
+        ref_output.float(),
+        atol=5e-2,
+        rtol=5e-2,
+    )
+

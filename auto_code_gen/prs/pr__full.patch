+def test_fa3_sparse_mla_backend_supports_combination():
+    """Test backend supports_combination for sparse MLA."""
+    from vllm.v1.attention.backends.mla.fa3_sparse_mla import (
+        FA3SparseMLABackend,
+    )
+    from vllm.platforms.interface import DeviceCapability
+
+    cap_sm90 = DeviceCapability(major=9, minor=0)
+    cap_sm100 = DeviceCapability(major=10, minor=0)
+
+    # Should support sparse MLA on SM90
+    result = FA3SparseMLABackend.supports_combination(
+        head_size=576,
+        dtype=torch.bfloat16,
+        kv_cache_dtype="bfloat16",
+        block_size=64,
+        use_mla=True,
+        has_sink=False,
+        use_sparse=True,
+        device_capability=cap_sm90,
+    )
+    # Result is None means supported (or unsupported reason string)
+    # It may fail due to flash_attn_supports_mla() check, which depends on
+    # runtime FA3 availability. We just check it doesn't crash.
+    assert result is None or isinstance(result, str)
+
+    # Should NOT support non-sparse
+    result_nonsparse = FA3SparseMLABackend.supports_combination(
+        head_size=576,
+        dtype=torch.bfloat16,
+        kv_cache_dtype="bfloat16",
+        block_size=64,
+        use_mla=True,
+        has_sink=False,
+        use_sparse=False,
+        device_capability=cap_sm90,
+    )
+    assert result_nonsparse is not None  # Should return unsupported reason
+
+    # Should NOT support FP8 KV cache
+    result_fp8 = FA3SparseMLABackend.supports_combination(
+        head_size=576,
+        dtype=torch.bfloat16,
+        kv_cache_dtype="fp8_ds_mla",
+        block_size=64,
+        use_mla=True,
+        has_sink=False,
+        use_sparse=True,
+        device_capability=cap_sm90,
+    )
+    assert result_fp8 is not None  # Should return unsupported reason

+def test_fa3_sparse_mla_topk_index_conversion():
+    """Test triton_convert_req_index_to_global_index for sparse indices."""
+    from vllm.v1.attention.backends.mla.sparse_utils import (
+        triton_convert_req_index_to_global_index,
+    )
+
+    block_size = 64
+    num_blocks_per_req = 32  # 32 blocks * 64 tokens = 2048 slots
+    num_reqs = 2
+    topk = 128
+
+    # Create block_table: maps (req_id, block_idx) -> physical block id
+    block_table = torch.arange(
+        num_reqs * num_blocks_per_req,
+        device="cuda",
+        dtype=torch.int32,
+    ).view(num_reqs, num_blocks_per_req)
+
+    # Create topk_indices: per-request relative token positions
+    # Request 0: tokens 0..topk-1
+    # Request 1: tokens 0..topk-1
+    topk_indices = torch.arange(
+        topk, device="cuda", dtype=torch.int32
+    ).unsqueeze(0).expand(num_reqs, -1).contiguous()
+
+    # req_id_per_token: 2 tokens, one per request
+    req_id_per_token = torch.tensor(
+        [0, 1], device="cuda", dtype=torch.int32
+    )
+
+    global_indices = triton_convert_req_index_to_global_index(
+        req_id_per_token,
+        block_table,
+        topk_indices,
+        BLOCK_SIZE=block_size,
+        NUM_TOPK_TOKENS=topk,
+    )
+
+    # Verify shape
+    assert global_indices.shape == (num_reqs, topk)
+
+    # Verify first request: token i maps to block_table[0, i//64] * 64 + i%64
+    for i in range(topk):
+        block_idx = i // block_size
+        offset = i % block_size
+        expected = block_table[0, block_idx].item() * block_size + offset
+        actual = global_indices[0, i].item()
+        assert actual == expected, (
+            f"Request 0, token {i}: expected {expected}, got {actual}"
+        )
+

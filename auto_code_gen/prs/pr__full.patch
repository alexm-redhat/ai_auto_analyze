+@pytest.mark.parametrize("batch_size", [1])
+def test_fa3_sparse_mla_performance(batch_size):
+    """Benchmark FA3 sparse MLA kernel time (should be < 30 us)."""
+    torch.manual_seed(42)
+    dtype = torch.bfloat16
+    num_heads = 16
+    kv_lora_rank = 512
+    qk_rope_dim = 64
+    total_slots = 8192
+    topk = 2048
+    scale = qk_rope_dim ** (-0.5)
+
+    q_pe = torch.randn(
+        batch_size, num_heads, qk_rope_dim, device="cuda", dtype=dtype
+    )
+    q_nope = torch.randn(
+        batch_size, num_heads, kv_lora_rank, device="cuda", dtype=dtype
+    )
+    k_pe_paged = torch.randn(
+        total_slots, 1, 1, qk_rope_dim, device="cuda", dtype=dtype
+    )
+    kv_c_paged = torch.randn(
+        total_slots, 1, 1, kv_lora_rank, device="cuda", dtype=dtype
+    )
+    topk_indices = torch.stack(
+        [
+            torch.randperm(total_slots, device="cuda")[:topk]
+            for _ in range(batch_size)
+        ]
+    ).to(torch.int32)
+    cu_seqlens_q = torch.arange(
+        0, batch_size + 1, device="cuda", dtype=torch.int32
+    )
+    seqused_k = torch.full(
+        (batch_size,), topk, device="cuda", dtype=torch.int32
+    )
+
+    sched_meta = get_scheduler_metadata(
+        batch_size=batch_size,
+        max_seqlen_q=1,
+        max_seqlen_k=topk,
+        num_heads_q=num_heads,
+        num_heads_kv=1,
+        headdim=qk_rope_dim,
+        cache_seqlens=seqused_k,
+        qkv_dtype=dtype,
+        headdim_v=kv_lora_rank,
+        page_size=1,
+        cu_seqlens_q=cu_seqlens_q,
+        causal=True,
+        num_splits=0,
+    )
+
+    def run():
+        return flash_attn_varlen_func(
+            q=q_pe,
+            k=k_pe_paged,
+            v=kv_c_paged,
+            q_v=q_nope,
+            max_seqlen_q=1,
+            cu_seqlens_q=cu_seqlens_q,
+            max_seqlen_k=topk,
+            seqused_k=seqused_k,
+            block_table=topk_indices,
+            softmax_scale=scale,
+            causal=True,
+            fa_version=3,
+            scheduler_metadata=sched_meta,
+            num_splits=0,
+        )
+
+    # Warmup
+    for _ in range(10):
+        run()
+    torch.cuda.synchronize()
+
+    # Benchmark
+    num_iters = 100
+    start = time.perf_counter()
+    for _ in range(num_iters):
+        run()
+    torch.cuda.synchronize()
+    elapsed = (time.perf_counter() - start) / num_iters * 1e6  # microseconds
+
+    print(f"\nFA3 Sparse MLA kernel time: {elapsed:.1f} us "
+          f"(B={batch_size}, H={num_heads}, topk={topk})")
+
+    # Should be significantly faster than the 63.78 us FlashMLA C kernel
+    assert elapsed < 100, (
+        f"FA3 Sparse MLA too slow: {elapsed:.1f} us "
+        f"(expected < 100 us, FlashMLA baseline ~64 us)"
+    )
+

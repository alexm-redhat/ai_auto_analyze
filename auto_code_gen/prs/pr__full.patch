+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""FA3-based Sparse MLA Attention Backend.
+
+Uses vLLM's existing FlashAttention-3 kernel (hopper/flash_api.cpp) with
+page_size=1 paged KV to implement sparse MLA attention. This replaces the
+slower FlashMLA C kernel (sparse_attn_fwd_kernel) with CUTLASS FA3 on SM90.
+
+Key differences from FlashMLASparseBackend:
+  - Uses FA3 (flash_attn_varlen_func with fa_version=3) instead of FlashMLA C
+  - BF16 KV cache (576 bytes/token) instead of FP8 (656 bytes/token)
+  - No head padding (FA3 handles arbitrary head counts natively)
+  - page_size=1 with topk_indices as block_table for sparse token access
+
+Ported from SGLang's nsa_backend._forward_fa3 pattern, adapted for vLLM's
+existing FA3 infrastructure and SparseMLAAttentionImpl interface.
+"""
+
+from dataclasses import dataclass
+from typing import TYPE_CHECKING, ClassVar
+
+import numpy as np
+import torch
+
+from vllm.config import VllmConfig
+from vllm.config.cache import CacheDType
+from vllm.logger import init_logger
+from vllm.model_executor.layers.attention.mla_attention import get_mla_dims
+from vllm.platforms.interface import DeviceCapability
+from vllm.utils.math_utils import round_up
+from vllm.v1.attention.backend import (
+    AttentionBackend,
+    AttentionCGSupport,
+    AttentionLayer,
+    AttentionMetadata,
+    AttentionMetadataBuilder,
+    CommonAttentionMetadata,
+    MultipleOf,
+    SparseMLAAttentionImpl,
+)
+from vllm.v1.attention.backends.fa_utils import (
+    flash_attn_supports_mla,
+    get_flash_attn_version,
+)
+from vllm.v1.attention.backends.mla.sparse_utils import (
+    triton_convert_req_index_to_global_index,
+)
+from vllm.v1.kv_cache_interface import AttentionSpec
+from vllm.vllm_flash_attn import (  # type: ignore[attr-defined]
+    flash_attn_varlen_func,
+    get_scheduler_metadata,
+)
+
+if TYPE_CHECKING:
+    from vllm.model_executor.models.deepseek_v2 import Indexer
+
+logger = init_logger(__name__)
+
+
+class FA3SparseMLABackend(AttentionBackend):
+    """FA3-based Sparse MLA attention backend for SM90 (Hopper).
+
+    Uses FlashAttention-3 with page_size=1 paged KV cache for sparse
+    MLA decode attention, replacing the slower FlashMLA C kernel.
+    """
+
+    accept_output_buffer: bool = True
+    supported_dtypes: ClassVar[list[torch.dtype]] = [torch.bfloat16]
+    supported_kv_cache_dtypes: ClassVar[list[CacheDType]] = [
+        "auto",
+        "bfloat16",
+    ]
+
+    @staticmethod
+    def get_supported_kernel_block_sizes() -> list[int | MultipleOf]:
+        # Any block size is fine for physical allocation.
+        # The sparse attention kernel uses page_size=1 internally.
+        return [MultipleOf(1)]
+
+    @staticmethod
+    def get_name() -> str:
+        return "FA3_SPARSE_MLA"
+
+    @staticmethod
+    def get_impl_cls() -> type["FA3SparseMLAImpl"]:
+        return FA3SparseMLAImpl
+
+    @staticmethod
+    def get_builder_cls() -> type["FA3SparseMLAMetadataBuilder"]:
+        return FA3SparseMLAMetadataBuilder
+
+    @classmethod
+    def get_supported_head_sizes(cls) -> list[int]:
+        return [576]
+
+    @classmethod
+    def is_mla(cls) -> bool:
+        return True
+
+    @classmethod
+    def is_sparse(cls) -> bool:
+        return True
+
+    @classmethod
+    def supports_compute_capability(cls, capability: DeviceCapability) -> bool:
+        return capability.major == 9  # SM90 (Hopper / H200)
+
+    @classmethod
+    def supports_combination(
+        cls,
+        head_size: int,
+        dtype: torch.dtype,
+        kv_cache_dtype: CacheDType | None,
+        block_size: int | None,
+        use_mla: bool,
+        has_sink: bool,
+        use_sparse: bool,
+        device_capability: DeviceCapability,
+    ) -> str | None:
+        if not flash_attn_supports_mla():
+            return "FlashAttention MLA not supported on this device"
+        if not use_sparse:
+            return "FA3SparseMLABackend only supports sparse MLA"
+        if kv_cache_dtype is not None and kv_cache_dtype.startswith("fp8"):
+            return "FA3SparseMLABackend requires BF16 KV cache"
+        return None
+
+    @staticmethod
+    def get_kv_cache_shape(
+        num_blocks: int,
+        block_size: int,
+        num_kv_heads: int,
+        head_size: int,
+        cache_dtype_str: str = "auto",
+    ) -> tuple[int, ...]:
+        # MLA stores (kv_c_normed + k_pe) = 576-dim in BF16
+        return (num_blocks, block_size, head_size)
+
+
+@dataclass
+class FA3SparseMLAMetadata(AttentionMetadata):
+    """Metadata for FA3 Sparse MLA attention."""
+
+    num_reqs: int
+    max_query_len: int
+    num_actual_tokens: int
+
+    # Topk / sparse parameters
+    topk: int
+    topk_seqlens: torch.Tensor  # (num_reqs,) all values = topk
+
+    # FA3 scheduling
+    query_start_loc: torch.Tensor
+    block_table: torch.Tensor
+    req_id_per_token: torch.Tensor
+    block_size: int
+
+    scheduler_metadata: torch.Tensor | None = None
+    max_num_splits: int = 0
+
+
+class FA3SparseMLAMetadataBuilder(
+    AttentionMetadataBuilder[FA3SparseMLAMetadata]
+):
+    """Builds FA3SparseMLAMetadata for each forward pass."""
+
+    _cudagraph_support: ClassVar[AttentionCGSupport] = (
+        AttentionCGSupport.UNIFORM_BATCH
+    )
+
+    def __init__(
+        self,
+        kv_cache_spec: AttentionSpec,
+        layer_names: list[str],
+        vllm_config: VllmConfig,
+        device: torch.device,
+    ) -> None:
+        self.vllm_config = vllm_config
+        self.layer_names = layer_names
+        self.kv_cache_spec = kv_cache_spec
+        self.device = device
+
+        model_config = vllm_config.model_config
+        parallel_config = vllm_config.parallel_config
+        compilation_config = vllm_config.compilation_config
+
+        self._init_reorder_batch_threshold(1, supports_spec_as_decode=True)
+
+        self.num_heads = model_config.get_num_attention_heads(parallel_config)
+        self.mla_dims = get_mla_dims(model_config)
+
+        # Sparse attention parameters
+        self.topk = model_config.hf_config.index_topk
+        self.page_size = kv_cache_spec.block_size
+
+        max_num_seqs = vllm_config.scheduler_config.max_num_seqs
+
+        # Pre-allocate constant topk seqlens tensor
+        self.topk_seqlens = torch.full(
+            (max_num_seqs,), self.topk, device=device, dtype=torch.int32
+        )
+
+        # req_id_per_token buffer for topk index conversion
+        self.req_id_per_token_buffer = torch.empty(
+            (vllm_config.scheduler_config.max_num_batched_tokens,),
+            dtype=torch.int32,
+            device=device,
+        )
+
+        # FA3 scheduling
+        self.fa_aot_schedule = get_flash_attn_version() == 3
+        self.use_full_cuda_graph = (
+            compilation_config.cudagraph_mode.has_full_cudagraphs()
+        )
+        self.max_cudagraph_size = compilation_config.max_cudagraph_capture_size
+        self.max_num_splits = 0
+
+        if self.use_full_cuda_graph and self.fa_aot_schedule:
+            max_batch_size = max(
+                max_num_seqs,
+                self.max_cudagraph_size or 0,
+            )
+            self.scheduler_metadata_buf = torch.zeros(
+                1 + round_up(max_batch_size, 4) * 4,
+                dtype=torch.int32,
+                device=self.device,
+            )
+            self.max_num_splits = (
+                vllm_config.attention_config.
+                flash_attn_max_num_splits_for_cuda_graph
+            )
+
+    def _schedule_decode(
+        self,
+        num_reqs: int,
+        cu_query_lens: torch.Tensor,
+        max_query_len: int,
+        max_num_splits: int,
+    ) -> torch.Tensor | None:
+        if not self.fa_aot_schedule:
+            return None
+        return get_scheduler_metadata(
+            batch_size=num_reqs,
+            max_seqlen_q=max_query_len,
+            max_seqlen_k=self.topk,
+            num_heads_q=self.num_heads,
+            num_heads_kv=1,
+            headdim=self.mla_dims.qk_rope_head_dim,
+            cache_seqlens=self.topk_seqlens[:num_reqs],
+            qkv_dtype=self.kv_cache_spec.dtype,
+            headdim_v=self.mla_dims.kv_lora_rank,
+            page_size=1,  # Sparse: each token is a "page"
+            cu_seqlens_q=cu_query_lens,
+            causal=True,
+            num_splits=max_num_splits,
+        )
+
+    def build(
+        self,
+        common_prefix_len: int,
+        common_attn_metadata: CommonAttentionMetadata,
+        fast_build: bool = False,
+    ) -> FA3SparseMLAMetadata:
+        cm = common_attn_metadata
+        num_tokens = cm.num_actual_tokens
+
+        # Build req_id_per_token for topk index conversion
+        starts = np.asarray(cm.query_start_loc_cpu, dtype=np.int32)
+        seg_lengths = np.diff(starts)
+        req_id_per_token = np.repeat(
+            np.arange(seg_lengths.shape[0], dtype=np.int32), seg_lengths
+        )
+        self.req_id_per_token_buffer.fill_(0)
+        self.req_id_per_token_buffer[:req_id_per_token.shape[0]].copy_(
+            torch.from_numpy(req_id_per_token), non_blocking=True
+        )
+
+        # Determine max_query_len and max_num_splits
+        query_lens_cpu = np.diff(starts)
+        max_query_len = int(query_lens_cpu.max()) if len(query_lens_cpu) > 0 else 1
+
+        max_num_splits = 0
+        if (
+            self.use_full_cuda_graph
+            and self.max_cudagraph_size is not None
+            and num_tokens <= self.max_cudagraph_size
+        ):
+            max_num_splits = self.max_num_splits
+
+        # Build FA3 scheduler metadata
+        scheduler_metadata = self._schedule_decode(
+            num_reqs=cm.num_reqs,
+            cu_query_lens=cm.query_start_loc,
+            max_query_len=max_query_len,
+            max_num_splits=max_num_splits,
+        )
+
+        if self.use_full_cuda_graph and scheduler_metadata is not None:
+            n = scheduler_metadata.shape[0]
+            assert n <= self.scheduler_metadata_buf.shape[0]
+            self.scheduler_metadata_buf[:n] = scheduler_metadata
+            self.scheduler_metadata_buf[n:] = 0
+            scheduler_metadata = self.scheduler_metadata_buf[:n]
+
+        return FA3SparseMLAMetadata(
+            num_reqs=cm.num_reqs,
+            max_query_len=max_query_len,
+            num_actual_tokens=num_tokens,
+            topk=self.topk,
+            topk_seqlens=self.topk_seqlens[:cm.num_reqs],
+            query_start_loc=cm.query_start_loc,
+            block_table=cm.block_table_tensor,
+            req_id_per_token=self.req_id_per_token_buffer[:num_tokens],
+            block_size=self.page_size,
+            scheduler_metadata=scheduler_metadata,
+            max_num_splits=max_num_splits,
+        )
+
+
+class FA3SparseMLAImpl(SparseMLAAttentionImpl[FA3SparseMLAMetadata]):
+    """FA3-based Sparse MLA attention implementation.
+
+    Uses FlashAttention-3 with page_size=1 paged KV and MLA qv parameter.
+    Ported from SGLang's nsa_backend._forward_fa3, adapted for vLLM's
+    flash_attn_varlen_func interface.
+    """
+
+    def __init__(
+        self,
+        num_heads: int,
+        head_size: int,
+        scale: float,
+        num_kv_heads: int,
+        alibi_slopes: list[float] | None,
+        sliding_window: int | None,
+        kv_cache_dtype: str,
+        logits_soft_cap: float | None,
+        attn_type: str,
+        kv_sharing_target_layer_name: str | None,
+        # MLA Specific Arguments
+        topk_indice_buffer: torch.Tensor | None = None,
+        indexer: "Indexer | None" = None,
+        **mla_args,
+    ) -> None:
+        self.num_heads = num_heads
+        self.head_size = head_size
+        self.scale = float(scale)
+        self.num_kv_heads = num_kv_heads
+        self.kv_cache_dtype = kv_cache_dtype
+
+        # MLA dimensions
+        self.kv_lora_rank: int = mla_args["kv_lora_rank"]
+        self.qk_rope_head_dim: int = mla_args["qk_rope_head_dim"]
+
+        # Indexer provides topk_indices buffer
+        assert indexer is not None, "FA3SparseMLAImpl requires an indexer"
+        self.topk_indices_buffer: torch.Tensor | None = (
+            indexer.topk_indices_buffer
+        )
+
+    def forward_mqa(
+        self,
+        q: torch.Tensor | tuple[torch.Tensor, torch.Tensor],
+        kv_c_and_k_pe_cache: torch.Tensor,
+        attn_metadata: FA3SparseMLAMetadata,
+        layer: AttentionLayer,
+    ) -> tuple[torch.Tensor, torch.Tensor | None]:
+        """Sparse MLA decode forward pass using FA3.
+
+        Args:
+            q: Either a tuple (q_nope, q_pe) or concatenated tensor.
+                q_nope: (num_tokens, num_heads, kv_lora_rank=512)
+                q_pe:   (num_tokens, num_heads, qk_rope_head_dim=64)
+            kv_c_and_k_pe_cache: Paged KV cache
+                Shape: (num_blocks, block_size, 576)
+            attn_metadata: FA3SparseMLAMetadata
+            layer: AttentionLayer with scaling info
+
+        Returns:
+            (attn_output, None): attn_output shape (num_tokens, num_heads, 512)
+        """
+        num_actual_toks = attn_metadata.num_actual_tokens
+
+        # 1. Unpack q into q_nope and q_pe
+        if type(q) is tuple:
+            q_nope, q_pe = q
+        else:
+            q_nope, q_pe = torch.split(
+                q, [self.kv_lora_rank, self.qk_rope_head_dim], dim=-1
+            )
+
+        # 2. Get topk_indices from indexer buffer
+        assert self.topk_indices_buffer is not None
+        topk_indices = self.topk_indices_buffer[:num_actual_toks]
+
+        # 3. Convert per-request topk indices to global cache slot indices
+        topk_indices = triton_convert_req_index_to_global_index(
+            attn_metadata.req_id_per_token,
+            attn_metadata.block_table,
+            topk_indices,
+            BLOCK_SIZE=attn_metadata.block_size,
+            NUM_TOPK_TOKENS=topk_indices.shape[1],
+        )
+
+        # 4. Split KV cache into kv_c (512-dim) and k_pe (64-dim)
+        kv_c_cache = kv_c_and_k_pe_cache[..., :self.kv_lora_rank]
+        k_pe_cache = kv_c_and_k_pe_cache[..., self.kv_lora_rank:]
+
+        # 5. Reshape KV cache for page_size=1 (each token is a "page")
+        #    Physical shape: (num_blocks, block_size, dim)
+        #    Virtual shape:  (num_blocks * block_size, 1, 1, dim)
+        total_slots = kv_c_cache.shape[0] * kv_c_cache.shape[1]
+        k_pe_paged = k_pe_cache.reshape(total_slots, 1, 1, -1)
+        kv_c_paged = kv_c_cache.reshape(total_slots, 1, 1, -1)
+
+        # 6. Call FA3 with paged sparse KV
+        max_seqlen_q = max(attn_metadata.max_query_len, 1)
+
+        attn_out = flash_attn_varlen_func(
+            q=q_pe,                     # (num_tokens, num_heads, 64)
+            k=k_pe_paged,              # (total_slots, 1, 1, 64)
+            v=kv_c_paged,              # (total_slots, 1, 1, 512)
+            q_v=q_nope,                # (num_tokens, num_heads, 512)
+            max_seqlen_q=max_seqlen_q,
+            cu_seqlens_q=attn_metadata.query_start_loc,
+            max_seqlen_k=attn_metadata.topk,
+            seqused_k=attn_metadata.topk_seqlens,
+            block_table=topk_indices,  # (num_tokens, topk) - sparse page table
+            softmax_scale=self.scale,
+            causal=True,
+            fa_version=3,
+            scheduler_metadata=attn_metadata.scheduler_metadata,
+            num_splits=attn_metadata.max_num_splits,
+        )
+
+        # 7. Return output
+        # flash_attn_varlen_func returns tensor directly (no LSE requested)
+        return attn_out, None

